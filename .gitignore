# ==================================
# OdaxEngine - .gitignore
# ==================================

# Dependencies
node_modules/
.pnp
.pnp.js
package-lock.json

# Testing
coverage/
*.log

# Next.js
.next/
out/

# Build artifacts
build/
dist/
*.tsbuildinfo

# OS files
.DS_Store
**/.DS_Store
Thumbs.db

# Keys & Certificates
*.pem
*.key
*.cert
*.p12

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env files
.env
.env.*
!.env.example
!.env.local.example
!.env.test.example

# Vercel
.vercel

# Turbo
.turbo

# IDEs
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea
*.swp
*.swo
*~

# Gemini / AI agents
.gemini/
.agent/

# code-server local data
apps/ide/data
apps/ide/config/code-server.sock

# Local models (large binary files)
packages/llm/models/*.gguf
packages/llm/models/*.bin

# Database
*.db
*.db-journal
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
*.tmp

# OdaxEngine local data
.odax/

# Backup & Archive (large, not needed in repo)
backup/
_archive/

# Python
venv/
__pycache__/
*.pyc
*.pyo
.Python

# macOS app build output
apps/macos/build/

# Logs
apps/logs/
logs/

# PDFs and large documents (user data)
*.pdf
services/odax-chat/public/*.pdf
services/odax-chat/app/components/*.pdf

# DMG installer builds
*.dmg

# Pre-built binaries (distributed via releases, not source)
apps/macos/resources/llama-server/*.dylib
apps/macos/resources/llama-server/llama-server
apps/macos/resources/llama-server/ggml-metal.metal
apps/macos/resources/extensions/*.vsix

# Editor swap files
*.swp
*.swo
*.swn
