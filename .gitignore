# ══════════════════════════════════════════════
#  OdaxAI Studio — .gitignore
# ══════════════════════════════════════════════

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js
package-lock.json

# ── Build / Output ───────────────────────────
.next/
out/
build/
dist/
*.tsbuildinfo

# ── Test / Coverage ──────────────────────────
coverage/

# ── Environment & Secrets ────────────────────
.env
.env.*
!.env.example
!.env.local.example
!.env.test.example
*.pem
*.key
*.cert
*.p12

# ── OS ───────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
apps/logs/
logs/

# ── IDEs & Editors ───────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
*~

# ── Tooling ──────────────────────────────────
.vercel
.turbo
turbo.json
pnpm-workspace.yaml
pnpm-lock.yaml
.gemini/
.agent/

# ── Vendored / Large repos (build from source) ─
server/llama.cpp/
server/whisper.cpp/

# ── Removed services (kept locally, not tracked) ─
services/code-server/
services/DeepResearch/
services/Perplexica/
services/anything-llm/
services/LibreChat/
apps/ide/
apps/desktop/
apps/macos/OdaxStudio/
apps/macos/config/
packages/db/
packages/llm/
packages/types/
packages/ui/
scripts/

# ── Runtime data ─────────────────────────────
.odax/
backup/
_archive/
tmp/
temp/
*.tmp

# ── Database ─────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3

# ── Python ───────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
.Python

# ── macOS App ────────────────────────────────
apps/macos/build/
apps/macos/project/*.xcodeproj/
apps/macos/project/*.xcworkspace/

# ── Binary assets (distributed via Releases) ─
apps/macos/resources/llama-server/*.dylib
apps/macos/resources/llama-server/llama-server
apps/macos/resources/llama-server/ggml-metal.metal
apps/macos/resources/extensions/*.vsix
*.dmg
*.pdf
