{
  "enable-crash-reporter": false,
  "crash-reporter-id": "",
  "enable-proposed-api": [
    "ggml-org.llama-vscode"
  ],
  "disable-hardware-acceleration": false,
  "disable-color-correct-rendering": false,
  "disable-gpu": false,
  "disable-gpu-compositing": false,
  "disable-gpu-sandbox": false,
  "disable-gpu-vsync": false,
  "disable-software-rasterizer": false,
  "disable-dev-shm-usage": false,
  "disable-namespace-sandbox": false,
  "disable-seccomp-filter-sandbox": false,
  "disable-setuid-sandbox": false,
  "js-flags": "--max-old-space-size=4096",
  "locale": "en"
}

