{
  "name": "odaxai-studio",
  "version": "1.1.0",
  "private": true,
  "description": "OdaxAI Studio — Local-first AI workspace for macOS",
  "scripts": {
    "dev": "cd services/odax-chat && npm run dev",
    "build": "cd services/odax-chat && npm run build",
    "test": "cd services/odax-chat && npm test",
    "lint": "cd services/odax-chat && npm run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "setup": "./setup.sh"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

