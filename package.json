{
  "name": "odaxai-studio",
  "version": "0.1.0",
  "private": true,
  "description": "OdaxAI Studio - Unified browser-first development environment",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "setup:ide": "cd apps/ide && pnpm run setup",
    "start:ide": "cd apps/ide && pnpm run start",
    "start:web": "cd apps/web && pnpm run dev",
    "start:all": "concurrently \"pnpm run start:ide\" \"pnpm run start:web\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@turbo/gen": "^1.11.2",
    "concurrently": "^8.2.2",
    "prettier": "^3.1.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}

